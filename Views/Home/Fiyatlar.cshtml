@{
    ViewData["Title"] = "Canlı Piyasa Fiyatları";
}

@section Scripts {
    <style>
        /* CSS kuralları - Tasarımın birebir korundu */
        .tablo-kart { border: 1px solid #e8e0d0; background: var(--beyaz); overflow: hidden; margin-bottom: 40px; }
        .tablo-kart .tablo-baslik-satiri { background: var(--siyah); padding: 18px 24px; display: flex; align-items: center; gap: 12px; border-bottom: 2px solid var(--altin); }
        .tablo-kart .tablo-baslik-satiri h4 { font-family: var(--font-baslik); color: var(--altin); font-size: 1.3rem; letter-spacing: 3px; text-transform: uppercase; margin: 0; font-weight: 400; }
        .guncelleme-etiketi { background: #111; border: 1px solid #2a2a2a; color: var(--gri); font-size: 0.72rem; letter-spacing: 2px; padding: 8px 16px; display: inline-flex; align-items: center; gap: 8px; }
        .guncelleme-etiketi .nokta { width: 7px; height: 7px; background: #2E7D32; border-radius: 50%; display: inline-block; animation: yanip-sonme 1.5s infinite; }
        @@keyframes yanip-sonme { 0%, 100% { opacity: 1; } 50% { opacity: 0.2; } }
        .piyasa-bilgi-kart { background: var(--siyah); border: 1px solid #2a2a2a; padding: 24px; text-align: center; transition: var(--gecis); }
        .piyasa-bilgi-kart:hover { border-color: var(--altin); }
        .piyasa-bilgi-kart .pb-ikon { font-size: 2rem; margin-bottom: 8px; }
        .piyasa-bilgi-kart .pb-deger { font-family: var(--font-baslik); font-size: 1.8rem; color: var(--altin); font-weight: 600; line-height: 1; }
        .piyasa-bilgi-kart .pb-adi { font-size: 0.65rem; letter-spacing: 3px; text-transform: uppercase; color: #555; margin-top: 6px; }
        .piyasa-bilgi-kart .pb-degisim { font-size: 0.78rem; margin-top: 6px; font-weight: 500; }
        .tablo-responsive-wrapper { overflow-x: auto; }
        
        /* Dinamik renk sınıfları */
        .deger-yukari { color: #2E7D32 !important; font-weight: 500; }
        .deger-asagi { color: #C62828 !important; font-weight: 500; }
    </style>
}

<div class="page-header-band">
    <p class="bolum-alt-yazi" style="color:#444;">Gerçek Zamanlı Veriler</p>
    <h1>Canlı Piyasa Fiyatları</h1>
    <div class="altin-cizgi"></div>
    <p>Altın, gümüş ve döviz alış–satış fiyatları</p>
    <div class="d-flex justify-content-center mt-3">
        <div class="guncelleme-etiketi">
            <span class="nokta"></span>
            <span>Son Güncelleme: <span id="saatGoster">--:--:--</span></span>
            <span>·</span>
            <span>Bilgi Amaçlıdır</span>
        </div>
    </div>
</div>

<main style="background:var(--krem);padding:60px 0;">
    <div class="container">
        <div class="row g-3 mb-5">
            <div class="col-6 col-md-3"><div class="piyasa-bilgi-kart"><div class="pb-ikon">🥇</div><div class="pb-deger" id="kart-gram-altin">...</div><div class="pb-adi">Gram Altın (TL)</div><div class="pb-degisim" id="kart-gram-altin-degisim" style="color:#2E7D32;">...</div></div></div>
            <div class="col-6 col-md-3"><div class="piyasa-bilgi-kart"><div class="pb-ikon">💵</div><div class="pb-deger" id="kart-usd">...</div><div class="pb-adi">USD / TL</div><div class="pb-degisim" id="kart-usd-degisim" style="color:#C62828;">...</div></div></div>
            <div class="col-6 col-md-3"><div class="piyasa-bilgi-kart"><div class="pb-ikon">💶</div><div class="pb-deger" id="kart-eur">...</div><div class="pb-adi">EUR / TL</div><div class="pb-degisim" id="kart-eur-degisim" style="color:#2E7D32;">...</div></div></div>
            <div class="col-6 col-md-3"><div class="piyasa-bilgi-kart"><div class="pb-ikon">🥈</div><div class="pb-deger" id="kart-gumus">...</div><div class="pb-adi">Gram Gümüş (TL)</div><div class="pb-degisim" id="kart-gumus-degisim" style="color:#2E7D32;">...</div></div></div>
        </div>

        <div class="tablo-kart">
            <div class="tablo-baslik-satiri"><i class="bi bi-gem"></i><h4>Altın Fiyatları</h4></div>
            <div class="tablo-responsive-wrapper">
                <table class="altin-tablo">
                    <thead><tr><th>Altın Türü</th><th>Alış (TL)</th><th>Satış (TL)</th><th>Gram</th><th>Ayar</th><th>Değişim</th></tr></thead>
                    <tbody>
                        <tr><td><strong>Gram Altın</strong></td><td id="ga-alis">...</td><td><strong id="ga-satis">...</strong></td><td>1 gr</td><td>24 Ayar</td><td id="ga-degisim" class="deger-yukari">...</td></tr>
                        <tr><td><strong>Çeyrek Altın</strong></td><td id="ca-alis">...</td><td><strong id="ca-satis">...</strong></td><td>1.608 gr</td><td>22 Ayar</td><td id="ca-degisim" class="deger-yukari">...</td></tr>
                        <tr><td><strong>Yarım Altın</strong></td><td id="ya-alis">...</td><td><strong id="ya-satis">...</strong></td><td>3.217 gr</td><td>22 Ayar</td><td id="ya-degisim" class="deger-yukari">...</td></tr>
                        <tr><td><strong>Tam Altın</strong></td><td id="ta-alis">...</td><td><strong id="ta-satis">...</strong></td><td>6.435 gr</td><td>22 Ayar</td><td id="ta-degisim" class="deger-yukari">...</td></tr>
                        <tr><td><strong>Ata Altın</strong></td><td id="ata-alis">...</td><td><strong id="ata-satis">...</strong></td><td>6.435 gr</td><td>22 Ayar</td><td id="ata-degisim" class="deger-asagi">...</td></tr>
                        <tr><td><strong>Beşli Altın</strong></td><td id="ba-alis">...</td><td><strong id="ba-satis">...</strong></td><td>32.175 gr</td><td>22 Ayar</td><td id="ba-degisim" class="deger-yukari">...</td></tr>
                        <tr><td><strong>Reşat Altın</strong></td><td id="res-alis">...</td><td><strong id="res-satis">...</strong></td><td>6.435 gr</td><td>22 Ayar</td><td id="res-degisim" class="deger-yukari">...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="tablo-kart">
            <div class="tablo-baslik-satiri"><i class="bi bi-bar-chart-steps"></i><h4>Ayara Göre Ham Altın</h4></div>
            <div class="tablo-responsive-wrapper">
                <table class="altin-tablo">
                    <thead><tr><th>Ayar</th><th>Alış</th><th>Satış</th><th>Saflık</th><th>Kullanım</th><th>Değişim</th></tr></thead>
                    <tbody>
                        <tr><td><strong>24 Ayar</strong></td><td id="a24-alis">...</td><td><strong id="a24-satis">...</strong></td><td>%99.9</td><td>Yatırım</td><td id="a24-degisim" class="deger-yukari">...</td></tr>
                        <tr><td><strong>22 Ayar</strong></td><td id="a22-alis">...</td><td><strong id="a22-satis">...</strong></td><td>%91.6</td><td>Bilezik</td><td id="a22-degisim" class="deger-yukari">...</td></tr>
                        <tr><td><strong>18 Ayar</strong></td><td id="a18-alis">...</td><td><strong id="a18-satis">...</strong></td><td>%75.0</td><td>Pırlanta</td><td id="a18-degisim" class="deger-yukari">...</td></tr>
                        <tr><td><strong>14 Ayar</strong></td><td id="a14-alis">...</td><td><strong id="a14-satis">...</strong></td><td>%58.5</td><td>Alyans</td><td id="a14-degisim" class="deger-asagi">...</td></tr>
                        <tr><td><strong>8 Ayar</strong></td><td id="a8-alis">...</td><td><strong id="a8-satis">...</strong></td><td>%33.3</td><td>Dekoratif</td><td id="a8-degisim" class="deger-yukari">...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="tablo-kart">
            <div class="tablo-baslik-satiri"><i class="bi bi-currency-exchange"></i><h4>Döviz Kurları</h4></div>
            <div class="tablo-responsive-wrapper">
                <table class="altin-tablo">
                    <thead><tr><th>Döviz</th><th>Alış</th><th>Satış</th><th>Önceki</th><th>Yüksek</th><th>Düşük</th><th>Değişim</th></tr></thead>
                    <tbody>
                        <tr><td><strong>USD — ABD Doları</strong></td><td id="usd-alis">...</td><td><strong id="usd-satis">...</strong></td><td id="usd-onceki">...</td><td id="usd-yuksek">...</td><td id="usd-dusuk">...</td><td id="usd-degisim" class="deger-asagi">...</td></tr>
                        <tr><td><strong>EUR — Euro</strong></td><td id="eur-alis">...</td><td><strong id="eur-satis">...</strong></td><td id="eur-onceki">...</td><td id="eur-yuksek">...</td><td id="eur-dusuk">...</td><td id="eur-degisim" class="deger-yukari">...</td></tr>
                        <tr><td><strong>GBP — İngiliz Sterlini</strong></td><td id="gbp-alis">...</td><td><strong id="gbp-satis">...</strong></td><td id="gbp-onceki">...</td><td id="gbp-yuksek">...</td><td id="gbp-dusuk">...</td><td id="gbp-degisim" class="deger-yukari">...</td></tr>
                        <tr><td><strong>CHF — İsviçre Frangı</strong></td><td id="chf-alis">...</td><td><strong id="chf-satis">...</strong></td><td id="chf-onceki">...</td><td id="chf-yuksek">...</td><td id="chf-dusuk">...</td><td id="chf-degisim" class="deger-yukari">...</td></tr>
                        <tr><td><strong>SAR — Suudi Riyali</strong></td><td id="sar-alis">...</td><td><strong id="sar-satis">...</strong></td><td id="sar-onceki">...</td><td id="sar-yuksek">...</td><td id="sar-dusuk">...</td><td id="sar-degisim" class="deger-asagi">...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
        
        <div class="tablo-kart">
            <div class="tablo-baslik-satiri"><i class="bi bi-circle-half"></i><h4>Gümüş Fiyatları</h4></div>
            <div class="tablo-responsive-wrapper">
                <table class="altin-tablo">
                    <thead><tr><th>Tür</th><th>Alış</th><th>Satış</th><th>Birim</th><th>Değişim</th></tr></thead>
                    <tbody>
                        <tr><td><strong>Gram Gümüş</strong></td><td id="g-gram-alis">...</td><td><strong id="g-gram-satis">...</strong></td><td>1 gram</td><td id="g-gram-degisim" class="deger-yukari">...</td></tr>
                        <tr><td><strong>Ons Gümüş</strong></td><td id="g-ons-alis">...</td><td><strong id="g-ons-satis">...</strong></td><td>31.1 gram</td><td id="g-ons-degisim" class="deger-yukari">...</td></tr>
                        <tr><td><strong>Gümüş 925</strong></td><td id="g-925-alis">...</td><td><strong id="g-925-satis">...</strong></td><td>1 gram</td><td id="g-925-degisim" class="deger-yukari">...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="fade-in-up" style="background:#fff;border-left:3px solid var(--altin);padding:18px 24px;font-size:0.83rem;color:#888;line-height:1.8;">
            <i class="bi bi-info-circle" style="color:var(--altin);margin-right:8px;"></i>
            <strong style="color:var(--siyah);">Önemli Not:</strong> Yukarıdaki fiyatlar bilgi amaçlıdır.
        </div>
    </div>
</main>

<script>
    // ================================================
    // 1. CANLI PİYASA MOTORU (Hafıza Destekli)
    // ================================================
    function canliFiyatlariGetir() {
        fetch('@Url.Action("GetLivePrices", "Home")')
            .then(response => response.json())
            .then(data => {
                if(data && data.success) {
                    var kurlar = data.data;

                    // Şimdiki tarih ve saati tam formatta al (Örn: 1.06.2026 17:09:00)
                    var simdi = new Date();
                    var tarihSaatStr = simdi.toLocaleDateString('tr-TR') + ' ' + simdi.toLocaleTimeString('tr-TR');

                    // Alınan bu gerçek verileri ve zaman damgasını tarayıcı hafızasına kilitle
                    localStorage.setItem('kuyumcu_son_kurlar', JSON.stringify(kurlar));
                    localStorage.setItem('kuyumcu_son_zaman', tarihSaatStr);

                    // Tabloyu ve üst kartları gerçek verilerle doldur
                    tabloyuVerilerleBesle(kurlar);

                    // Üstteki bildirim bandını "Canlı" moduna al
                    durumSeridiniGuncelle(true, tarihSaatStr);
                } else {
                    // API bağlandı ama boş veri gönderdiyse hafızaya dön
                    hafizadakiSonVeriyiYukle();
                }
            })
            .catch(error => {
                // İnternet kesilirse, CORS engeli çıkarsa veya API çökerse burası çalışır
                console.log("Canlı fiyatlar çekilemedi, hafızadaki arşiv verileri yükleniyor.");
                hafizadakiSonVeriyiYukle();
            });
    }

    // ================================================
    // 2. HAFIZADAN ESKİ VERİYİ ÇEKME MOTORU
    // ================================================
    function hafizadakiSonVeriyiYukle() {
        var eskiKurlar = localStorage.getItem('kuyumcu_son_kurlar');
        var eskiZaman = localStorage.getItem('kuyumcu_son_zaman');

        if (eskiKurlar && eskiZaman) {
            // Eğer hafızada daha önce kaydedilmiş bir başarılı veri varsa onu bas
            var kurlarNesnesi = JSON.parse(eskiKurlar);
            tabloyuVerilerleBesle(kurlarNesnesi);

            // Sitedeki uyarı bandını kırmızı yap ve tam o tarihi söyle
            durumSeridiniGuncelle(false, eskiZaman);
        } else {
            // Eğer site ilk kez açıldıysa ve hafızada hiç veri yoksa taslak veriler kalır
            durumSeridiniGuncelle(false, "Veri Alınamadı (İnternet Bağlantınızı Kontrol Edin)");
        }
    }

    // ================================================
    // 3. TABLO VE KARTLARI BESLEYEN ORTAK METOD
    // ================================================
    function tabloyuVerilerleBesle(kurlar) {
        // --- 1. DÖVİZ KURLARINI DOLDUR (Yüksek/Düşük dahil) ---
        function dovizSatiriDoldur(kod, dataObj) {
            var satis = parseFloat(dataObj.satis);
            var alis = satis * 0.985;
            var onceki = parseFloat(dataObj.onceki);
            
            // Günlük Yüksek / Düşük Simülasyonu (Alıştan %0.4 düşük, Satıştan %0.5 yüksek)
            var yuksek = satis * 1.005;
            var dusuk = alis * 0.996;

            if(document.getElementById(kod + '-alis')) {
                document.getElementById(kod + '-alis').textContent = alis.toFixed(2);
                document.getElementById(kod + '-satis').textContent = satis.toFixed(2);
                document.getElementById(kod + '-onceki').textContent = onceki.toFixed(2);
                document.getElementById(kod + '-yuksek').textContent = yuksek.toFixed(2);
                document.getElementById(kod + '-dusuk').textContent = dusuk.toFixed(2);
                renkliDegisimYaz(kod + '-degisim', dataObj.degisim);
                
                // Üstteki kartlar için (Sadece USD ve EUR var)
                if(document.getElementById('kart-' + kod)) {
                    document.getElementById('kart-' + kod).textContent = satis.toFixed(2);
                    renkliDegisimYaz('kart-' + kod + '-degisim', dataObj.degisim);
                }
            }
        }

        dovizSatiriDoldur('usd', kurlar.USD);
        dovizSatiriDoldur('eur', kurlar.EUR);
        dovizSatiriDoldur('gbp', kurlar.GBP);
        dovizSatiriDoldur('chf', kurlar.CHF);
        dovizSatiriDoldur('sar', kurlar.SAR);

        // --- 2. ALTIN TABLOLARINI DOLDUR ---
        var gaAlis = parseFloat(kurlar.GA.alis);
        var gaSatis = parseFloat(kurlar.GA.satis);
        var aDegisim = kurlar.GA.degisim; // Altın değişimi

        // Gram Altın Üst Kart
        document.getElementById('kart-gram-altin').textContent = formatPara(gaSatis);
        renkliDegisimYaz('kart-gram-altin-degisim', aDegisim);

        // Satır Doldurucu Yardımcı Fonksiyon
        function altinSatir(id, alisC, satisC) {
            if(document.getElementById(id + '-alis')){
                document.getElementById(id + '-alis').textContent = formatPara(alisC);
                document.getElementById(id + '-satis').textContent = formatPara(satisC);
                renkliDegisimYaz(id + '-degisim', aDegisim);
            }
        }

        altinSatir('ga', gaAlis, gaSatis);
        altinSatir('ca', gaAlis * 1.63, gaSatis * 1.65);
        altinSatir('ya', gaAlis * 3.26, gaSatis * 3.30);
        altinSatir('ta', gaAlis * 6.52, gaSatis * 6.60);
        altinSatir('ata', gaAlis * 6.57, gaSatis * 6.63);
        altinSatir('ba', gaAlis * 32.6, gaSatis * 33.0);
        altinSatir('res', gaAlis * 6.8, gaSatis * 6.9);

        // Ham Altın Ayarları
        altinSatir('a24', gaAlis, gaSatis);
        altinSatir('a22', gaAlis * 0.916, gaSatis * 0.916);
        altinSatir('a18', gaAlis * 0.750, gaSatis * 0.750);
        altinSatir('a14', gaAlis * 0.585, gaSatis * 0.585);
        altinSatir('a8', gaAlis * 0.333, gaSatis * 0.333);


        // --- 3. GÜMÜŞ TABLOSUNU DOLDUR ---
        var gAlis = parseFloat(kurlar.GUMUS.alis);
        var gSatis = parseFloat(kurlar.GUMUS.satis);
        var gOns = parseFloat(kurlar.GUMUS.ons);
        
        // Gümüş Üst Kart
        document.getElementById('kart-gumus').textContent = gSatis.toFixed(2);
        renkliDegisimYaz('kart-gumus-degisim', kurlar.GUMUS.degisim);

        if(document.getElementById('g-gram-alis')){
            document.getElementById('g-gram-alis').textContent = gAlis.toFixed(2);
            document.getElementById('g-gram-satis').textContent = gSatis.toFixed(2);
            renkliDegisimYaz('g-gram-degisim', kurlar.GUMUS.degisim);

            document.getElementById('g-ons-alis').textContent = (gOns - 0.20).toFixed(2);
            document.getElementById('g-ons-satis').textContent = gOns.toFixed(2);
            renkliDegisimYaz('g-ons-degisim', kurlar.GUMUS.degisim);

            document.getElementById('g-925-alis').textContent = (gAlis * 0.925).toFixed(2);
            document.getElementById('g-925-satis').textContent = (gSatis * 0.925).toFixed(2);
            renkliDegisimYaz('g-925-degisim', kurlar.GUMUS.degisim);
        }
    }

    // Pozitif/Negatif duruma göre Ok ve Renk basan fonksiyon
    function renkliDegisimYaz(elementId, degisimDegeri) {
        var el = document.getElementById(elementId);
        if(!el) return;
        var deger = parseFloat(degisimDegeri || 0);
        
        if(deger > 0) {
            el.innerHTML = "▲ +%" + deger.toFixed(2);
            el.className = "deger-yukari";
            el.style.color = "#2E7D32";
        } else if(deger < 0) {
            el.innerHTML = "▼ -%" + Math.abs(deger).toFixed(2);
            el.className = "deger-asagi";
            el.style.color = "#C62828";
        } else {
            el.innerHTML = "━ %0.00";
            el.className = "";
            el.style.color = "#888";
        }
    }

    // ================================================
    // 4. BİLDİRİM ŞERİDİNİ DİNAMİKLEŞTİREN METOD
    // ================================================
    function durumSeridiniGuncelle(isLive, zamanMesaji) {
        var nokta = document.querySelector('.guncelleme-etiketi .nokta');
        var saatYaziAlani = document.getElementById('saatGoster');
        
        if (isLive) {
            nokta.style.background = "#2E7D32"; // Canlı yeşil nokta
            saatYaziAlani.parentElement.innerHTML = 'Son Güncelleme: <span id="saatGoster">' + zamanMesaji + '</span>';
        } else {
            nokta.style.background = "#C62828"; // Hata uyarısı kırmızı nokta
            // Tam senin istediğin o net cümleyi buraya gömüyoruz:
            saatYaziAlani.parentElement.innerHTML = '<span id="saatGoster" style="color:#ff8a80; font-weight:bold;">Bu veriler tam ' + zamanMesaji + ' tarihine ait arşiv verileridir.</span>';
        }
    }

    function formatPara(deger) {
        return parseFloat(deger).toLocaleString('tr-TR', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
    }

    // Sayfa açıldığında ilk sorguyu at ve her 60 saniyede bir canlığı kontrol et
    document.addEventListener('DOMContentLoaded', function() {
        canliFiyatlariGetir();
        setInterval(canliFiyatlariGetir, 60000); 
    });
</script>