@section Scripts {
    <style>
        /* ---- Bu sayfaya özel stiller ---- */
        .filtre-cubugu {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            justify-content: center;
            margin: 30px 0 40px;
        }

        .filtre-btn {
            font-family: var(--font-metin);
            font-size: 0.68rem;
            letter-spacing: 2.5px;
            text-transform: uppercase;
            padding: 9px 22px;
            border: 1px solid #d4c9a8;
            background: transparent;
            color: var(--gri);
            cursor: pointer;
            transition: var(--gecis);
        }

        .filtre-btn:hover,
        .filtre-btn.aktif {
            background: var(--siyah);
            border-color: var(--siyah);
            color: var(--altin);
        }

        /* ---- ÜRÜN KARTLARI (Gelişmiş hover efekti) ---- */
        .urun-kart-wrapper {
            overflow: hidden;
            position: relative;
            background: var(--beyaz);
            border: 1px solid #e8e0d0;
            transition: transform 0.4s ease, box-shadow 0.4s ease, border-color 0.3s ease;
            margin-bottom: 30px;
        }

        .urun-kart-wrapper:hover {
            transform: translateY(-8px) scale(1.01);
            box-shadow: 0 20px 50px rgba(0,0,0,0.14), 0 0 0 1px var(--altin);
            border-color: var(--altin);
        }

        .urun-kart-gorsel {
            position: relative;
            height: 280px;
            overflow: hidden;
            background: #f5edd8;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .urun-kart-gorsel .emoji-gorsel {
            font-size: 6rem;
            transition: transform 0.5s ease;
            user-select: none;
        }

        .urun-kart-wrapper:hover .emoji-gorsel {
            transform: scale(1.12) rotate(-3deg);
        }

        .urun-rozet {
            position: absolute;
            top: 14px;
            left: 14px;
            background: var(--siyah);
            color: var(--altin);
            font-size: 0.6rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            padding: 5px 10px;
        }

        .urun-rozet-yeni {
            position: absolute;
            top: 14px;
            right: 14px;
            background: var(--altin);
            color: var(--siyah);
            font-size: 0.6rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            padding: 5px 10px;
            font-weight: 700;
        }

        .urun-kart-gorsel .overlay {
            position: absolute;
            inset: 0;
            background: rgba(10,10,10,0.5);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .urun-kart-wrapper:hover .overlay {
            opacity: 1;
        }

        .overlay .hizli-incele {
            background: transparent;
            border: 1px solid var(--altin);
            color: var(--altin);
            font-family: var(--font-metin);
            font-size: 0.65rem;
            letter-spacing: 3px;
            text-transform: uppercase;
            padding: 10px 22px;
            text-decoration: none;
            transform: translateY(10px);
            transition: all 0.3s ease 0.1s;
        }

        .urun-kart-wrapper:hover .overlay .hizli-incele {
            transform: translateY(0);
        }

        .overlay .hizli-incele:hover {
            background: var(--altin);
            color: var(--siyah);
        }

        .urun-kart-bilgi {
            padding: 20px 22px;
            border-top: 1px solid #f0ebe0;
        }

        .urun-kart-bilgi .kategori {
            font-size: 0.62rem;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: var(--altin);
            margin-bottom: 5px;
        }

        .urun-kart-bilgi .isim {
            font-family: var(--font-baslik);
            font-size: 1.25rem;
            font-weight: 600;
            color: var(--siyah);
            margin-bottom: 4px;
            line-height: 1.3;
        }

        .urun-kart-bilgi .aciklama {
            font-size: 0.78rem;
            color: var(--gri);
            margin-bottom: 14px;
        }

        .urun-kart-bilgi .alt-satir {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .urun-kart-bilgi .fiyat {
            font-family: var(--font-baslik);
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--altin-koyu);
        }

        .btn-detay {
            font-family: var(--font-metin);
            font-size: 0.62rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            padding: 8px 18px;
            border: 1px solid var(--siyah);
            background: transparent;
            color: var(--siyah);
            text-decoration: none;
            transition: var(--gecis);
            display: inline-block;
        }

        .btn-detay:hover {
            background: var(--siyah);
            color: var(--altin);
        }

        .sonuc-etiketi {
            font-size: 0.75rem;
            color: var(--gri);
            letter-spacing: 1px;
            margin-bottom: 20px;
        }
    </style>

    <script>
        // ================================================
        // KATEGORİ FİLTRELEME
        // ================================================
        document.addEventListener('DOMContentLoaded', function() {
            const filtreButonlari = document.querySelectorAll('.filtre-btn');
            const urunKartlari    = document.querySelectorAll('.urun-oget');
            const sonucEtiketi    = document.getElementById('sonucSayisi');

            filtreButonlari.forEach(function(buton) {
                buton.addEventListener('click', function() {
                    filtreButonlari.forEach(b => b.classList.remove('aktif'));
                    this.classList.add('aktif');

                    var seciliFiltre = this.getAttribute('data-filtre');
                    var gorünürSayisi = 0;

                    urunKartlari.forEach(function(kart) {
                        var kartKategori = kart.getAttribute('data-kategori');

                        if (seciliFiltre === 'tumu' || kartKategori === seciliFiltre) {
                            kart.style.display = 'block';
                            kart.style.opacity = '0';
                            kart.style.transform = 'translateY(16px)';
                            setTimeout(function() {
                                kart.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
                                kart.style.opacity = '1';
                                kart.style.transform = 'translateY(0)';
                            }, 50);
                            gorünürSayisi++;
                        } else {
                            kart.style.display = 'none';
                        }
                    });

                    sonucEtiketi.textContent = gorünürSayisi + ' ürün listeleniyor';
                });
            });
        });
    </script>
}

