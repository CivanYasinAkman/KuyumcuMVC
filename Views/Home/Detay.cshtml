@section Scripts {
    <script>
        // ================================================
        // SEKME SİSTEMİ
        // ================================================
        document.addEventListener('DOMContentLoaded', function() {
            const tabButonlari = document.querySelectorAll('.tab-btn');
            const tabIcerikleri = document.querySelectorAll('.tab-icerik');

            tabButonlari.forEach(function(buton) {
                buton.addEventListener('click', function() {
                    var hedefTab = this.getAttribute('data-tab');

                    tabButonlari.forEach(b => b.classList.remove('aktif'));
                    tabIcerikleri.forEach(t => t.classList.remove('aktif'));

                    this.classList.add('aktif');
                    document.getElementById('tab-' + hedefTab).classList.add('aktif');
                });
            });

            // ================================================
            // THUMBNAIL SEÇİMİ
            // ================================================
            const thumbnaillar = document.querySelectorAll('.thumbnail');
            thumbnaillar.forEach(function(thumb) {
                thumb.addEventListener('click', function() {
                    thumbnaillar.forEach(t => t.classList.remove('aktif'));
                    this.classList.add('aktif');
                });
            });
        });
        // ================================================
            // RESİM DEĞİŞTİRME FONKSİYONU
            // ================================================
            window.resimDegistir = function(element, resimYolu) {
                document.getElementById('anaResim').src = resimYolu;
                document.querySelectorAll('.thumbnail').forEach(t => t.classList.remove('aktif'));
                element.classList.add('aktif');
            };
    </script>
}