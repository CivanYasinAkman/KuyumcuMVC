<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Altın Dünya Kuyumculuk</title>

    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>💍</text></svg>" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/KuyumcuMVC.styles.css" asp-append-version="true" />
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-kuyumcu">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                ALTIN DÜNYA
                <span>K U Y U M C U L U K</span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#anaMenu"
                    aria-controls="anaMenu" aria-expanded="false" aria-label="Menüyü aç/kapat">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="anaMenu">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Urunler">Ürünler</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Fiyatlar">Canlı Fiyatlar</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Iletisim">İletişim</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="site-footer mt-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <h5>Altın Dünya</h5>
                    <p style="font-size:0.83rem;line-height:1.8;color:#777;">
                        1994 yılından bu yana Mersin'de kuyumculuk sektörünün güvenilir ismi olarak hizmet vermekteyiz.
                        El işçiliği, şeffaf fiyat, kaliteli altın.
                    </p>
                    <div class="mt-3" style="display:flex;gap:12px;">
                        <a href="#" style="width:34px;height:34px;border:1px solid #2a2a2a;display:flex;align-items:center;justify-content:center;color:#888;transition:all .3s;" onmouseover="this.style.borderColor='var(--altin)';this.style.color='var(--altin)'" onmouseout="this.style.borderColor='#2a2a2a';this.style.color='#888'"><i class="bi bi-instagram"></i></a>
                        <a href="#" style="width:34px;height:34px;border:1px solid #2a2a2a;display:flex;align-items:center;justify-content:center;color:#888;transition:all .3s;" onmouseover="this.style.borderColor='var(--altin)';this.style.color='var(--altin)'" onmouseout="this.style.borderColor='#2a2a2a';this.style.color='#888'"><i class="bi bi-facebook"></i></a>
                        <a href="#" style="width:34px;height:34px;border:1px solid #2a2a2a;display:flex;align-items:center;justify-content:center;color:#888;transition:all .3s;" onmouseover="this.style.borderColor='var(--altin)';this.style.color='var(--altin)'" onmouseout="this.style.borderColor='#2a2a2a';this.style.color='#888'"><i class="bi bi-whatsapp"></i></a>
                    </div>
                </div>

                <div class="col-md-2 col-sm-6">
                    <h5>Sayfalar</h5>
                    <ul>
                        <li><a asp-controller="Home" asp-action="Index"><i class="bi bi-chevron-right" style="font-size:0.6rem;margin-right:4px;color:var(--altin);"></i>Ana Sayfa</a></li>
                        <li><a asp-controller="Home" asp-action="Urunler"><i class="bi bi-chevron-right" style="font-size:0.6rem;margin-right:4px;color:var(--altin);"></i>Ürünler</a></li>
                        <li><a asp-controller="Home" asp-action="Fiyatlar"><i class="bi bi-chevron-right" style="font-size:0.6rem;margin-right:4px;color:var(--altin);"></i>Canlı Fiyatlar</a></li>
                        <li><a asp-controller="Home" asp-action="Iletisim"><i class="bi bi-chevron-right" style="font-size:0.6rem;margin-right:4px;color:var(--altin);"></i>İletişim</a></li>
                    </ul>
                </div>

                <div class="col-md-2 col-sm-6">
                    <h5>Ürünler</h5>
                    <ul>
                        <li><a asp-controller="Home" asp-action="Urunler">Bilezikler</a></li>
                        <li><a asp-controller="Home" asp-action="Urunler">Yüzükler</a></li>
                        <li><a asp-controller="Home" asp-action="Urunler">Kolyeler</a></li>
                        <li><a asp-controller="Home" asp-action="Urunler">Küpeler</a></li>
                        <li><a asp-controller="Home" asp-action="Urunler">Altın Sikke</a></li>
                    </ul>
                </div>

                <div class="col-md-4">
                    <h5>İletişim</h5>
                    <ul style="color:#777;font-size:0.83rem;line-height:2;">
                        <li><i class="bi bi-geo-alt" style="color:var(--altin);margin-right:6px;"></i>Çankaya Cad. No:14, Mersin</li>
                        <li><i class="bi bi-telephone" style="color:var(--altin);margin-right:6px;"></i>0324 321 45 67</li>
                        <li><i class="bi bi-envelope" style="color:var(--altin);margin-right:6px;"></i>info@altindunya.com.tr</li>
                        <li><i class="bi bi-clock" style="color:var(--altin);margin-right:6px;"></i>Pzt–Cmt: 09:00–19:30</li>
                    </ul>
                </div>
            </div>

            <div class="footer-alt mt-4 pt-3 border-top border-secondary">
                <p class="mb-0">© 2026 Altın Dünya Kuyumculuk. Tüm hakları saklıdır.</p>
                <p style="margin-top:4px;font-size:0.7rem;color:#333;">Web Programlama Dersi Projesi — HTML5, CSS3, Bootstrap 5</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // Sayfa scroll animasyonu (IntersectionObserver)
        const gizliler = document.querySelectorAll('.fade-in-up');
        const gozlemci = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.style.opacity = '1';
                    entry.target.style.transform = 'translateY(0)';
                }
            });
        }, { threshold: 0.1 });

        gizliler.forEach(el => {
            el.style.opacity = '0';
            el.style.transform = 'translateY(24px)';
            el.style.transition = 'opacity 0.7s ease, transform 0.7s ease';
            gozlemci.observe(el);
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>